LIST P=16F887
    #include <P16F887.INC>

    __CONFIG _CONFIG1, _XT_OSC & _WDT_OFF & _LVP_OFF & _MCLRE_ON
    __CONFIG _CONFIG2, _BOR4V_BOR40V & _WRT_OFF

; Variables
TEMP        EQU 0x20
DIGITO      EQU 0x21
INDICE      EQU 0x22
DISPLAY1    EQU 0x23
DISPLAY3    EQU 0x24
DISPLAY4    EQU 0x25
FAIL_FLAG   EQU 0x26
RX_CHAR     EQU 0x27
UART_NUM    EQU 0x28
RX_DIG      EQU 0x29
SETPOINT    EQU 0x2A
SET_ADC     EQU 0x2B

W_TEMP      EQU 0x70
STATUS_TEMP EQU 0x71

; Vectores
    ORG 0x00
    GOTO INICIO

    ORG 0x04
    GOTO ISR

; Configuracion inicial
INICIO

    BANKSEL TRISB
    MOVLW   b'00000101'
    MOVWF   TRISB

    BANKSEL TRISA
    MOVLW   b'00000000'
    MOVWF   TRISA

    BANKSEL TRISD
    CLRF    TRISD

    BANKSEL TRISC
    MOVLW   b'10000000'
    MOVWF   TRISC

    BANKSEL ANSEL
    CLRF    ANSEL

    BANKSEL ANSELH
    MOVLW   b'00000001'
    MOVWF   ANSELH

    BANKSEL CM1CON0
    CLRF    CM1CON0
    CLRF    CM2CON0

    BANKSEL ADCON1
    CLRF    ADCON1

    BANKSEL ADCON0
    MOVLW   b'01000001'
    MOVWF   ADCON0
    BSF     ADCON0, CHS3
    BCF     ADCON0, CHS2
    BCF     ADCON0, CHS1
    BCF     ADCON0, CHS0

    BANKSEL SPBRG
    MOVLW   d'25'
    MOVWF   SPBRG

    BANKSEL BAUDCTL
    BCF     BAUDCTL, BRG16

    BANKSEL TXSTA
    BSF     TXSTA, BRGH
    BCF     TXSTA, SYNC
    BSF     TXSTA, TXEN

    BANKSEL RCSTA
    BSF     RCSTA, SPEN
    BSF     RCSTA, CREN

    BANKSEL WPUB
    MOVLW   b'00000001'
    MOVWF   WPUB

    BANKSEL OPTION_REG
    BCF     OPTION_REG, NOT_RBPU
    BCF     OPTION_REG, INTEDG
    BCF     OPTION_REG, T0CS
    BCF     OPTION_REG, PSA
    BCF     OPTION_REG, PS2
    BSF     OPTION_REG, PS1
    BCF     OPTION_REG, PS0

    BANKSEL PORTA
    MOVLW   b'11111111'
    MOVWF   PORTA

    BANKSEL PORTB
    CLRF    PORTB
    BSF     PORTB, 7

    BANKSEL PORTD
    MOVLW   0xFF
    MOVWF   PORTD

    BANKSEL DISPLAY1
    CLRF    INDICE
    CLRF    FAIL_FLAG
    CLRF    UART_NUM

    MOVLW   d'100'
    MOVWF   SETPOINT
    MOVLW   d'85'
    MOVWF   SET_ADC

    MOVLW   0xBF
    MOVWF   DISPLAY1

    MOVLW   0xC0
    MOVWF   DISPLAY3

    MOVLW   0xBF
    MOVWF   DISPLAY4

    MOVLW   0xC0
    MOVWF   DIGITO

    BANKSEL TMR0
    MOVLW   .200
    MOVWF   TMR0

    BANKSEL INTCON
    BCF     INTCON, INTF
    BCF     INTCON, T0IF
    BSF     INTCON, INTE
    BSF     INTCON, T0IE
    BSF     INTCON, GIE

    GOTO    MAIN

; Interrupciones
ISR
    MOVWF   W_TEMP
    SWAPF   STATUS, W
    MOVWF   STATUS_TEMP

    BCF     STATUS, RP0
    BCF     STATUS, RP1

    BTFSC   INTCON, T0IF
    GOTO    ISR_TMR0

    BTFSC   INTCON, INTF
    GOTO    ISR_EMER

    GOTO    FIN_ISR

ISR_TMR0
    BCF     INTCON, T0IF

    MOVLW   .200
    MOVWF   TMR0

    MOVLW   .4
    SUBWF   INDICE, W
    BTFSC   STATUS, Z
    CLRF    INDICE

    MOVLW   b'11111111'
    MOVWF   PORTA

    MOVF    INDICE, W
    BTFSC   STATUS, Z
    GOTO    M_DISPLAY1

    MOVF    INDICE, W
    XORLW   .1
    BTFSC   STATUS, Z
    GOTO    M_DISPLAY2

    MOVF    INDICE, W
    XORLW   .2
    BTFSC   STATUS, Z
    GOTO    M_DISPLAY3

    GOTO    M_DISPLAY4

M_DISPLAY1
    BTFSC   FAIL_FLAG, 0
    GOTO    FAIL_D1

    MOVF    DISPLAY1, W
    MOVWF   PORTD
    GOTO    ENC_D1

FAIL_D1
    MOVLW   0x8E
    MOVWF   PORTD

ENC_D1
    MOVLW   b'11111110'
    MOVWF   PORTA
    INCF    INDICE, F
    GOTO    FIN_ISR

M_DISPLAY2
    BTFSC   FAIL_FLAG, 0
    GOTO    FAIL_D2

    MOVF    DIGITO, W
    MOVWF   PORTD
    GOTO    ENC_D2

FAIL_D2
    MOVLW   0x88
    MOVWF   PORTD

ENC_D2
    MOVLW   b'11111101'
    MOVWF   PORTA
    INCF    INDICE, F
    GOTO    FIN_ISR

M_DISPLAY3
    BTFSC   FAIL_FLAG, 0
    GOTO    FAIL_D3

    MOVF    DISPLAY3, W
    MOVWF   PORTD
    GOTO    ENC_D3

FAIL_D3
    MOVLW   0xF9
    MOVWF   PORTD

ENC_D3
    MOVLW   b'11111011'
    MOVWF   PORTA
    INCF    INDICE, F
    GOTO    FIN_ISR

M_DISPLAY4
    BTFSC   FAIL_FLAG, 0
    GOTO    FAIL_D4

    MOVF    DISPLAY4, W
    MOVWF   PORTD
    GOTO    ENC_D4

FAIL_D4
    MOVLW   0xC7
    MOVWF   PORTD

ENC_D4
    MOVLW   b'11110111'
    MOVWF   PORTA
    INCF    INDICE, F
    GOTO    FIN_ISR

ISR_EMER
    BSF     FAIL_FLAG, 0
    BSF     PORTB, 4
    BCF     PORTB, 7
    BCF     INTCON, INTE
    BCF     INTCON, INTF
    GOTO    FIN_ISR

FIN_ISR
    SWAPF   STATUS_TEMP, W
    MOVWF   STATUS
    SWAPF   W_TEMP, F
    SWAPF   W_TEMP, W
    RETFIE

; Recepcion UART
CHECK_UART
    BANKSEL PIR1
    BTFSS   PIR1, RCIF
    RETURN

    BANKSEL RCSTA
    BTFSC   RCSTA, OERR
    GOTO    UART_OVERRUN

    BANKSEL RCREG
    MOVF    RCREG, W
    BANKSEL RX_CHAR
    MOVWF   RX_CHAR

    MOVF    RX_CHAR, W
    XORLW   0x0D
    BTFSC   STATUS, Z
    GOTO    UART_ENTER

    MOVF    RX_CHAR, W
    XORLW   0x0A
    BTFSC   STATUS, Z
    GOTO    UART_ENTER

    MOVLW   '0'
    SUBWF   RX_CHAR, W
    BTFSS   STATUS, C
    RETURN

    MOVWF   RX_DIG

    MOVLW   d'10'
    SUBWF   RX_DIG, W
    BTFSC   STATUS, C
    RETURN

    MOVF    UART_NUM, W
    MOVWF   TEMP
    BCF     STATUS, C
    RLF     TEMP, F

    BCF     STATUS, C
    RLF     UART_NUM, F
    RLF     UART_NUM, F
    RLF     UART_NUM, F

    MOVF    TEMP, W
    ADDWF   UART_NUM, F

    MOVF    RX_DIG, W
    ADDWF   UART_NUM, F

    RETURN

UART_ENTER
    MOVLW   d'101'
    SUBWF   UART_NUM, W
    BTFSC   STATUS, C
    GOTO    UART_SET_100

    MOVF    UART_NUM, W
    MOVWF   SETPOINT
    GOTO    UART_FIN_ENTER

UART_SET_100
    MOVLW   d'100'
    MOVWF   SETPOINT

UART_FIN_ENTER
    CLRF    UART_NUM
    CALL    SETPOINT_TO_ADC
    RETURN

UART_OVERRUN
    BCF     RCSTA, CREN
    BSF     RCSTA, CREN
    RETURN

; Conversion del setpoint a umbral ADC
SETPOINT_TO_ADC
    MOVLW   d'100'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_100

    MOVLW   d'90'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_90

    MOVLW   d'80'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_80

    MOVLW   d'70'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_70

    MOVLW   d'60'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_60

    MOVLW   d'50'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_50

    MOVLW   d'40'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_40

    MOVLW   d'30'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_30

    MOVLW   d'20'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_20

    MOVLW   d'10'
    SUBWF   SETPOINT, W
    BTFSC   STATUS, C
    GOTO    SETADC_10

SETADC_0
    MOVLW   d'57'
    MOVWF   SET_ADC
    RETURN
SETADC_10
    MOVLW   d'58'
    MOVWF   SET_ADC
    RETURN
SETADC_20
    MOVLW   d'60'
    MOVWF   SET_ADC
    RETURN
SETADC_30
    MOVLW   d'62'
    MOVWF   SET_ADC
    RETURN
SETADC_40
    MOVLW   d'64'
    MOVWF   SET_ADC
    RETURN
SETADC_50
    MOVLW   d'67'
    MOVWF   SET_ADC
    RETURN
SETADC_60
    MOVLW   d'71'
    MOVWF   SET_ADC
    RETURN
SETADC_70
    MOVLW   d'74'
    MOVWF   SET_ADC
    RETURN
SETADC_80
    MOVLW   d'77'
    MOVWF   SET_ADC
    RETURN
SETADC_90
    MOVLW   d'79'
    MOVWF   SET_ADC
    RETURN
SETADC_100
    MOVLW   d'85'
    MOVWF   SET_ADC
    RETURN

; Control de bomba
ACTUALIZA_BOMBA
    BANKSEL FAIL_FLAG
    BTFSC   FAIL_FLAG, 0
    RETURN

    MOVF    SETPOINT, F
    BTFSC   STATUS, Z
    GOTO    BOMBA_OFF

    BANKSEL ADRESH
    MOVF    SET_ADC, W
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    BOMBA_OFF

BOMBA_ON
    BANKSEL PORTB
    BSF     PORTB, 7
    RETURN

BOMBA_OFF
    BANKSEL PORTB
    BCF     PORTB, 7
    RETURN

; Programa principal
MAIN

    BANKSEL PORTB
    BTFSS   PORTB, 0
    GOTO    BOTON_APRETADO

BOTON_SUELTO
    BANKSEL FAIL_FLAG
    BCF     FAIL_FLAG, 0

    BANKSEL PORTB
    BCF     PORTB, 4

    BANKSEL INTCON
    BCF     INTCON, INTF
    BSF     INTCON, INTE

    GOTO    SIGUE_NORMAL

BOTON_APRETADO
    BANKSEL FAIL_FLAG
    BSF     FAIL_FLAG, 0

    BANKSEL PORTB
    BSF     PORTB, 4
    BCF     PORTB, 7

    GOTO    MAIN

SIGUE_NORMAL

    CALL    CHECK_UART

    BANKSEL TEMP
    MOVLW   d'50'
    MOVWF   TEMP

ESPERA
    DECFSZ  TEMP, F
    GOTO    ESPERA

    BANKSEL ADCON0
    BSF     ADCON0, GO

ESPERAR_ADC
    BTFSC   ADCON0, GO
    GOTO    ESPERAR_ADC

    CALL    ACTUALIZA_BOMBA

    BANKSEL ADRESH

    MOVLW   d'85'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_LLENO

    MOVLW   d'79'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_9

    MOVLW   d'77'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_8

    MOVLW   d'74'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_7

    MOVLW   d'71'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_6

    MOVLW   d'67'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_5

    MOVLW   d'64'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_4

    MOVLW   d'62'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_3

    MOVLW   d'60'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_2

    MOVLW   d'58'
    SUBWF   ADRESH, W
    BTFSC   STATUS, C
    GOTO    ES_1

    GOTO    ES_0

; Actualizacion de displays
ES_LLENO
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xC0
    MOVWF   DISPLAY4
    MOVLW   0xF9
    MOVWF   DIGITO
    GOTO    MAIN

ES_0
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0xC0
    MOVWF   DIGITO
    GOTO    MAIN

ES_1
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0xF9
    MOVWF   DIGITO
    GOTO    MAIN

ES_2
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0xA4
    MOVWF   DIGITO
    GOTO    MAIN

ES_3
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0xB0
    MOVWF   DIGITO
    GOTO    MAIN

ES_4
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0x99
    MOVWF   DIGITO
    GOTO    MAIN

ES_5
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0x92
    MOVWF   DIGITO
    GOTO    MAIN

ES_6
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0x82
    MOVWF   DIGITO
    GOTO    MAIN

ES_7
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0xF8
    MOVWF   DIGITO
    GOTO    MAIN

ES_8
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0x80
    MOVWF   DIGITO
    GOTO    MAIN

ES_9
    BANKSEL DISPLAY1
    MOVLW   0xBF
    MOVWF   DISPLAY1
    MOVLW   0xC0
    MOVWF   DISPLAY3
    MOVLW   0xBF
    MOVWF   DISPLAY4
    MOVLW   0x90
    MOVWF   DIGITO
    GOTO    MAIN

    END
